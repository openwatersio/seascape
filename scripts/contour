#!/usr/bin/env bash
# Generate bathymetric contour vector tiles with non-uniform intervals.
#
# Generates contours at specific depth levels defined in config.sh, applies
# Chaikin corner-cutting for naturally curved lines, then tiles to PMTiles.
#
# Usage:
#   ./scripts/contour [input.tif]

source "$(dirname "$0")/config.sh"
check_deps gdal_contour ogr2ogr tippecanoe

SCRIPT_DIR="$(dirname "$0")"
resolve_input_dem "${1:-}"
OUTPUT_FGB="${WORK_DIR}/contours_enriched${SUFFIX}.fgb"

# Set SKIP_SLOPE_SMOOTH=1 to skip slope-selective DEM smoothing before contouring.
# Smoothing blurs flat areas (ocean floor) while preserving detail in steep
# terrain. See scripts/smooth-dem for tuning parameters.
SKIP_SLOPE_SMOOTH="${SKIP_SLOPE_SMOOTH:-}"
SKIP_CHAIKIN="${SKIP_CHAIKIN:-}"

log "Input DEM: ${INPUT_TIF}"

# ─── Step 1: Slope-selective DEM smoothing (optional, default on) ────────────
DEM="${INPUT_TIF}"
if [[ -z "${SKIP_SLOPE_SMOOTH}" ]]; then
  SMOOTHED="${OUTPUT_FGB%.fgb}_smoothed.tif"
  if cached "${SMOOTHED}"; then
    log "Smoothed DEM already exists"
  else
    rm -f "${SMOOTHED}"
    log "Applying slope-selective smoothing..."
    "${SCRIPT_DIR}/smooth-dem" "${DEM}" "${SMOOTHED}"
  fi
  DEM="${SMOOTHED}"
fi

# ─── Step 2: Generate contours at fixed levels ───────────────────────────────
CONTOURS_RAW="${OUTPUT_FGB%.fgb}_raw.fgb"

if cached "${CONTOURS_RAW}"; then
  log "Raw contours already exist"
else
  rm -f "${CONTOURS_RAW}"
  log "Generating contours..."
  gdal_contour -fl ${CONTOUR_LEVELS} -a depth_m -f FlatGeobuf \
    "${DEM}" "${CONTOURS_RAW}"
  COUNT=$(ogrinfo -al -so "${CONTOURS_RAW}" 2>/dev/null | grep "Feature Count" | awk '{print $NF}')
  log "  → ${COUNT} features"
fi

# ─── Step 3: Smooth contour geometries (Chaikin) ─────────────────────────────
CONTOURS_SMOOTH="${OUTPUT_FGB%.fgb}_smooth.fgb"

if [[ -n "${SKIP_CHAIKIN}" ]]; then
  CONTOURS_SMOOTH="${CONTOURS_RAW}"
  log "Skipping Chaikin smoothing"
elif cached "${CONTOURS_SMOOTH}"; then
  log "Smoothed contours already exist"
else
  rm -f "${CONTOURS_SMOOTH}"
  log "Smoothing contour geometries..."
  python3 "${SCRIPT_DIR}/smooth-contours" \
    "${CONTOURS_RAW}" "${CONTOURS_SMOOTH}" 0.0002 5
fi

# ─── Step 4: Enrich attributes ───────────────────────────────────────────────
if cached "${OUTPUT_FGB}"; then
  log "Enriched contours already exist"
else
  rm -f "${OUTPUT_FGB}"
  log "Enriching contours..."
  # Clip to OSM water polygons if available, to remove any contours that fall
  # on land. This is more accurate than the depth_m < 0 filter alone.
  ogr2ogr -f FlatGeobuf "${OUTPUT_FGB}" "${CONTOURS_SMOOTH}" \
    -dialect sqlite \
    -sql "
      SELECT geometry, depth_m,
        CAST(-depth_m AS INTEGER) AS depth_abs_m
      FROM contour
      WHERE depth_m < 0
    "
  COUNT=$(ogrinfo -al -so "${OUTPUT_FGB}" 2>/dev/null | grep "Feature Count" | awk '{print $NF}')
  log "  → ${COUNT} ocean features"
fi

# Clean up intermediates (never the input DEM)
rm -f "${CONTOURS_RAW}" "${CONTOURS_SMOOTH}"
[[ -n "${SKIP_SLOPE_SMOOTH}" ]] || rm -f "${SMOOTHED}"

# ─── Step 5: Tile to PMTiles ─────────────────────────────────────────────────
CONTOUR_PMTILES="${OUTPUT_DIR}/contours${SUFFIX}.pmtiles"
if cached "${CONTOUR_PMTILES}"; then
  log "Contour tiles already exist: ${CONTOUR_PMTILES}"
else
  log "Building contour vector tiles (z0–${MAX_ZOOM})..."
  tippecanoe \
    -o "${CONTOUR_PMTILES}" \
    -f \
    -l contours \
    -n "GEBCO Bathymetric Contours" \
    -A '<a href="https://www.gebco.net">GEBCO</a>' \
    -N "Bathymetric contour lines derived from the GEBCO grid." \
    -Z 0 -z "${MAX_ZOOM}" -P -q \
    -y depth_m -y depth_abs_m \
    -j '{
      "*": [
        "any",
        ["all", ["<=", "$zoom", 4],  ["<=", "depth_m", -1000]],
        ["all", ["<=", "$zoom", 6],  ["<=", "depth_m", -200]],
        ["all", ["<=", "$zoom", 8],  ["<=", "depth_m", -50]],
        [">=", "$zoom", 9]
      ]
    }' \
    "${OUTPUT_FGB}"
  log "Contour tiles: ${CONTOUR_PMTILES} ($(du -h "${CONTOUR_PMTILES}" | cut -f1))"
fi

log "Contours: ${CONTOUR_PMTILES}"
