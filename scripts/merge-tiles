#!/usr/bin/env bash
# Union raster MBTiles bands into one. The base owns z0–9 and each region owns
# z10+ within its bbox, so tile keys never collide across bands — a plain union
# (INSERT OR IGNORE) is correct, no blending needed.
#
# Usage: ./scripts/merge-tiles out.mbtiles base.mbtiles [region.mbtiles ...]

set -euo pipefail
OUT="${1:?Usage: merge-tiles out.mbtiles base.mbtiles [more...]}"; shift
BASE="${1:?need at least one input}"; shift

rm -f "${OUT}"
cp "${BASE}" "${OUT}"
# Make the union idempotent: with a unique key, INSERT OR IGNORE dedups identical
# tiles (e.g. two regions overlapping in the same zoom band). Bands are disjoint
# by design, so this is just insurance.
sqlite3 "${OUT}" "CREATE UNIQUE INDEX IF NOT EXISTS tiles_key ON tiles(zoom_level,tile_column,tile_row);"
for db in "$@"; do
  [[ -f "${db}" ]] || continue
  sqlite3 "${OUT}" "ATTACH '${db}' AS s; INSERT OR IGNORE INTO tiles SELECT * FROM s.tiles; DETACH s;"
done

# Widen the metadata zoom range to span every band actually present.
minz="$(sqlite3 "${OUT}" 'SELECT MIN(zoom_level) FROM tiles;')"
maxz="$(sqlite3 "${OUT}" 'SELECT MAX(zoom_level) FROM tiles;')"
sqlite3 "${OUT}" "INSERT OR REPLACE INTO metadata(name,value) VALUES('minzoom','${minz}'),('maxzoom','${maxz}');"

echo "${OUT}"
