#!/bin/bash
set -euo pipefail

server_id=${1:?usage: collect-hcloud-metrics SERVER_ID [OUTPUT_DIR]}
out=${2:-hcloud-metrics}
: "${HCLOUD_TOKEN:?HCLOUD_TOKEN is required}"
api=${HCLOUD_API:-https://api.hetzner.cloud/v1}
auth="Authorization: Bearer $HCLOUD_TOKEN"

mkdir -p "$out"
curl -fsS --connect-timeout 10 --max-time 60 -H "$auth" \
  "$api/servers/$server_id" -o "$out/server.json"

start=$(jq -er .server.created "$out/server.json")
end=$(date -u +%Y-%m-%dT%H:%M:%SZ)
to_epoch() {
  date -u -d "$1" +%s 2>/dev/null || date -j -u -f %Y-%m-%dT%H:%M:%SZ "$1" +%s
}
start_epoch=$(to_epoch "$start")
end_epoch=$(to_epoch "$end")
step=$(( (end_epoch - start_epoch + 1399) / 1400 ))
[ "$step" -ge 60 ] || step=60

curl -fsSG --connect-timeout 10 --max-time 120 -H "$auth" \
  --data-urlencode 'type=cpu,disk,network' \
  --data-urlencode "start=$start" \
  --data-urlencode "end=$end" \
  --data-urlencode "step=$step" \
  "$api/servers/$server_id/metrics" -o "$out/metrics.json"
jq -e '.metrics.time_series | length > 0' "$out/metrics.json" >/dev/null

jq -n --arg server_id "$server_id" --arg start "$start" --arg end "$end" \
  --argjson step "$step" \
  '{server_id: $server_id, start: $start, end: $end, step_seconds: $step}' \
  > "$out/request.json"

echo "Hetzner metrics: server=$server_id start=$start end=$end step=${step}s"
