#!/usr/bin/env bash
# Slope-selective DEM smoothing using GDAL + an out-of-core Gaussian blur.
#
# Blurs the DEM in flat areas (abyssal plains, shelves) to reduce noise-driven
# contour stairstepping, while preserving detail in steep terrain (canyon walls,
# seamount flanks). Both the DEM and the transition masks are blurred to avoid
# hard edges at the steep/flat boundary.
#
# The blur (scripts/blur) streams the raster in windows, so this scales to the
# full global GEBCO grid — unlike ImageMagick, which loads the whole image.
#
# Based on: https://hkartor.se/anteckningar/contour_lines_script.html
#
# Usage:
#   ./scripts/smooth-dem input.tif output.tif [dem_blur] [mask_blur] [slope_low] [slope_high]
#
#   dem_blur    DEM blur:   "radiusxsigma" pixels (default: 20x35)
#   mask_blur   Mask blur:  "radiusxsigma" pixels (default: 40x35)
#   slope_low   Slope below which DEM is fully blurred, degrees (default: 1)
#   slope_high  Slope above which DEM is fully original, degrees (default: 5)

set -euo pipefail
source "$(dirname "$0")/config.sh"
check_deps gdaldem gdal_calc.py python3

SCRIPT_DIR="$(dirname "$0")"
INPUT_TIF="${1:?Usage: smooth-dem input.tif output.tif}"
OUTPUT_TIF="${2:?Usage: smooth-dem input.tif output.tif}"
DEM_BLUR="${3:-20x35}"
MASK_BLUR="${4:-40x35}"
SLOPE_LOW="${5:-1}"
SLOPE_HIGH="${6:-5}"

WORK="$(dirname "${OUTPUT_TIF}")"

log "Slope-selective DEM smoothing (dem_blur=${DEM_BLUR}, mask_blur=${MASK_BLUR}, slope ${SLOPE_LOW}°–${SLOPE_HIGH}°)..."

# ─── Step 1: Prepare DEM for blurring ────────────────────────────────────────
# Clamp land (>= 0) to sea level so high coastal elevations don't drag the blur
# of nearby ocean pixels. scripts/blur works on Float32 directly, so unlike the
# old ImageMagick path there's no UInt16 offset/precision loss.
log "  Clamping land to sea level..."
gdal_calc.py -A "${INPUT_TIF}" \
  --calc="numpy.where(A >= 0, 0, A).astype(numpy.float32)" \
  --outfile="${WORK}/_sdem_prep.tif" \
  --type=Float32 --format=GTiff --quiet

# ─── Step 2: Blur DEM (out-of-core) ──────────────────────────────────────────
log "  Blurring DEM (${DEM_BLUR})..."
python3 "${SCRIPT_DIR}/blur" "${WORK}/_sdem_prep.tif" "${WORK}/_sdem_blurred.tif" "${DEM_BLUR}"

# ─── Step 3: Compute slope map from original DEM ────────────────────────────
log "  Computing slope..."
gdaldem slope "${INPUT_TIF}" "${WORK}/_sdem_slope.tif" -compute_edges 2>/dev/null

# ─── Step 4: Create steep and flat masks via color-relief ───────────────────
log "  Building slope masks..."
cat > "${WORK}/_sdem_steep_ramp.txt" <<EOF
0       0   0   0
${SLOPE_LOW}    0   0   0
${SLOPE_HIGH}  255 255 255
90    255 255 255
EOF
cat > "${WORK}/_sdem_flat_ramp.txt" <<EOF
0     255 255 255
${SLOPE_LOW}   255 255 255
${SLOPE_HIGH}    0   0   0
90     0   0   0
EOF

gdaldem color-relief "${WORK}/_sdem_slope.tif" "${WORK}/_sdem_steep_ramp.txt" \
  "${WORK}/_sdem_steep_mask.tif" 2>/dev/null
gdaldem color-relief "${WORK}/_sdem_slope.tif" "${WORK}/_sdem_flat_ramp.txt" \
  "${WORK}/_sdem_flat_mask.tif" 2>/dev/null

# ─── Step 5: Blur masks (out-of-core) ────────────────────────────────────────
log "  Blurring masks (${MASK_BLUR})..."
python3 "${SCRIPT_DIR}/blur" "${WORK}/_sdem_steep_mask.tif" "${WORK}/_sdem_steep_mask_blurred.tif" "${MASK_BLUR}"
python3 "${SCRIPT_DIR}/blur" "${WORK}/_sdem_flat_mask.tif"  "${WORK}/_sdem_flat_mask_blurred.tif"  "${MASK_BLUR}"

# ─── Step 6: Blend ──────────────────────────────────────────────────────────
log "  Blending..."
gdal_calc.py \
  -A "${INPUT_TIF}" \
  -B "${WORK}/_sdem_blurred.tif" \
  -C "${WORK}/_sdem_steep_mask_blurred.tif" --C_band=1 \
  -D "${WORK}/_sdem_flat_mask_blurred.tif"  --D_band=1 \
  --calc="numpy.where(A >= 0, A, (A * (C/255.0)) + (B * (D/255.0)))" \
  --outfile="${OUTPUT_TIF}" \
  --type=Float32 --format=GTiff \
  --creation-option=COMPRESS=LZW --creation-option=TILED=YES \
  --quiet

# ─── Cleanup ─────────────────────────────────────────────────────────────────
rm -f "${WORK}"/_sdem_*.tif "${WORK}"/_sdem_*.txt

log "  → ${OUTPUT_TIF}"
