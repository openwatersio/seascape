#!/usr/bin/env bash
# Download GEBCO gridded bathymetry data.
#
# Usage:
#   ./scripts/download                    # download full global grid
#   BBOX="-85,20,-70,35" ./scripts/download  # clip to Bahamas
#
# The GEBCO grid is ~7.5 GB. If BBOX is set, the script downloads the full
# grid and clips to the bounding box, producing a smaller working file.

source "$(dirname "$0")/config.sh"
check_deps curl gdal_translate gdalbuildvrt jq

# ─── Resolve GEBCO source ─────────────────────────────────────────────────────
# The archive may contain a single global TIF or multiple sub-grid tiles.
# We check for a VRT (virtual mosaic) first, then a single TIF.

if [[ -f "${GEBCO_VRT}" ]]; then
  GEBCO_SRC="${GEBCO_VRT}"
  log "Using existing GEBCO mosaic: ${GEBCO_VRT}"
elif [[ -f "${GEBCO_TIF}" ]]; then
  GEBCO_SRC="${GEBCO_TIF}"
  log "GEBCO GeoTIFF already exists: ${GEBCO_TIF}"
  log "Delete it to re-download."
else
  if [[ -f "${GEBCO_ZIP}" ]]; then
    log "ZIP already downloaded, extracting..."
  else
    log "Downloading GEBCO grid (~4.2 GB)..."
    # CEDA can stall mid-transfer; retry and resume (-C -) instead of failing.
    curl -L --fail --retry 5 --retry-all-errors --retry-delay 15 \
      --connect-timeout 30 -C - -o "${GEBCO_ZIP}" "${GEBCO_URL}"
  fi

  log "Extracting GeoTIFF from archive..."
  cd "${DATA_DIR}"
  unzip -o "${GEBCO_ZIP}" -d "${DATA_DIR}" >&2

  # Collect all extracted TIFs (excluding our own output name).
  TILES=()
  while IFS= read -r f; do
    [[ "$f" != "${GEBCO_TIF}" ]] && TILES+=("$f")
  done < <(find "${DATA_DIR}" -maxdepth 1 \( -name 'GEBCO_*.tif' -o -name 'gebco_*.tif' \) | sort)

  if [[ ${#TILES[@]} -eq 0 ]]; then
    log "ERROR: Could not find any GeoTIFF files in extracted archive."
    log "Contents of ${DATA_DIR}:"
    ls -la "${DATA_DIR}" >&2
    exit 1
  elif [[ ${#TILES[@]} -eq 1 ]]; then
    if [[ "${TILES[0]}" != "${GEBCO_TIF}" ]]; then
      mv "${TILES[0]}" "${GEBCO_TIF}"
    fi
    GEBCO_SRC="${GEBCO_TIF}"
    log "Extracted: ${GEBCO_TIF}"
  else
    log "Found ${#TILES[@]} sub-grid tiles, building virtual mosaic..."
    gdalbuildvrt "${GEBCO_VRT}" "${TILES[@]}" >&2
    GEBCO_SRC="${GEBCO_VRT}"
    log "Built mosaic: ${GEBCO_VRT}"
  fi
fi

# ─── Clip to bounding box ────────────────────────────────────────────────────
# Always clip to ±85° latitude to avoid expensive polar rendering.
# BBOX further restricts the region if set.
if [[ -n "${BBOX}" ]]; then
  IFS=',' read -r WEST SOUTH EAST NORTH <<< "${BBOX}"
else
  WEST=-180 SOUTH=-85 EAST=180 NORTH=85
fi

# Clamp latitude to ±85°
(( $(echo "${SOUTH} < -85" | bc -l) )) && SOUTH=-85
(( $(echo "${NORTH} > 85" | bc -l) )) && NORTH=85

CLIPPED="${WORK_DIR}/gebco_clipped${BBOX:+_${BBOX}}.tif"
if cached "${CLIPPED}"; then
  log "Clipped DEM already exists: ${CLIPPED}"
else
  log "Clipping to BBOX: ${WEST} ${SOUTH} ${EAST} ${NORTH}..."
  gdal_translate \
    -projwin "${WEST}" "${NORTH}" "${EAST}" "${SOUTH}" \
    "${GEBCO_SRC}" "${CLIPPED}" >&2
  log "Clipped output: ${CLIPPED}"
fi

echo "${CLIPPED}"
