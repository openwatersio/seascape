#!/usr/bin/env bash
# Build the priority mosaic VRT: GEBCO base first, regional overrides stacked on
# top. gdalbuildvrt draws later sources over earlier ones in areas of overlap,
# so listing worst→best (priority ascending) makes the best data win per pixel.
#
# -resolution highest keeps the regions at native resolution. The VRT is virtual,
# so the (huge) global grid costs nothing — scripts/build only ever reads small
# windows from it (the clipped regional bands).
#
# Usage: ./scripts/mosaic   → prints the VRT path

source "$(dirname "$0")/config.sh"
check_deps gdalbuildvrt

BASE="${WORK_DIR}/gebco_clipped${BBOX:+_${BBOX}}.tif"
[[ -f "${BASE}" ]] || { log "ERROR: base DEM not found (${BASE}). Run ./scripts/download first."; exit 1; }

# gdalbuildvrt refuses to mosaic heterogeneous band types (e.g. Int16 GEBCO +
# Float32 CUDEM — it silently skips the mismatched source). Wrap every input in
# a Float32 VRT (virtual, instant) so they're homogeneous.
promote() {
  local out="${WORK_DIR}/$(basename "${1%.*}")_f32.vrt"
  gdal_translate -q -of VRT -ot Float32 "$1" "${out}" >/dev/null
  echo "${out}"
}

# Regional norms in priority order (ascending → drawn after the base, best last).
inputs=("$(promote "${BASE}")")
while IFS='|' read -r id _; do
  [[ -n "${id}" ]] || continue
  norm="${WORK_DIR}/${id}_norm.tif"
  [[ -f "${norm}" ]] || { log "ERROR: ${norm} missing. Run ./scripts/ingest ${id}."; exit 1; }
  inputs+=("$(promote "${norm}")")
done < <(sources_rows | sort -t'|' -k4,4n)

log "Building priority mosaic from ${#inputs[@]} source(s)..."
gdalbuildvrt -resolution highest -overwrite "${MOSAIC_VRT}" "${inputs[@]}" >&2
echo "${MOSAIC_VRT}"
